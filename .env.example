# Exemple de configuration carbon-fr. Copier en `.env` et adapter.
# Détail des variables : docstring de bin/server/src/main.rs.

# ─── Requis ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://carbonfr:change-me@localhost:5432/carbonfr

# ─── Réseau / proxy ──────────────────────────────────────────────────────────
CARBONFR_BIND=0.0.0.0:8080
# À activer UNIQUEMENT derrière un reverse proxy de confiance qui réécrit
# X-Forwarded-For (sinon l'en-tête est spoofable).
CARBONFR_TRUST_PROXY=0

# ─── Sécurité ────────────────────────────────────────────────────────────────
# OBLIGATOIRE en production : sel secret à haute entropie pour le hachage des IP
# visiteurs (le défaut public rendrait les empreintes réversibles).
CARBONFR_VISIT_SALT=change-me-with-a-long-random-secret

# ─── Tier hébergé (optionnel, ADR-0015) ──────────────────────────────────────
CARBONFR_RATELIMIT_ENABLED=0
# CARBONFR_RATELIMIT_ANON_PER_MIN=60
# CARBONFR_RATELIMIT_FREE_PER_MIN=600

# ─── Sources / réglages (optionnels) ─────────────────────────────────────────
# CARBONFR_ENTSOE_TOKEN=             # si défini : acv-ademe@2 (imports transfrontaliers) + prix spot /v1/price
# CARBONFR_ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api
# CARBONFR_ENTSOE_WINDOW_HOURS=6     # fenêtre récente interrogée par cycle
# CARBONFR_POLL_SECS=900
# CARBONFR_DB_MAX_CONNECTIONS=20     # pool partagé API + poller + watcher
# CARBONFR_LOG_FORMAT=json           # logs structurés en prod
# RUST_LOG=info

# ─── Calibration au démarrage (optionnels) ───────────────────────────────────
# CARBONFR_FORECAST_CALIBRATE_WEEKS=8    # intervalles de prévision (0 = off)
# CARBONFR_RENEWABLE_CALIBRATE_WEEKS=52  # modèle /v1/renewable (0 = off)
