meta {
  name: Intensité now — régional Bretagne (acv-ademe)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v1/intensity/now?region=bretagne&methodology=acv-ademe
  body: none
  auth: none
}

params:query {
  region: bretagne
  methodology: acv-ademe
}

assert {
  res.status: eq 200
  res.body.region: eq bretagne
  res.body.methodology: eq acv-ademe
}
