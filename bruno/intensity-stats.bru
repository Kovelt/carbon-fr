meta {
  name: Intensité stats — résumé (national)
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/v1/intensity/stats?from=2024-01-01T00:00:00Z&to=2024-01-08T00:00:00Z
  body: none
  auth: none
}

params:query {
  from: 2024-01-01T00:00:00Z
  to: 2024-01-08T00:00:00Z
}

assert {
  res.status: eq 200
  res.body.unit: eq gCO2eq/kWh
  res.body.average: isNumber
}
